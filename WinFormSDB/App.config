<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2"/>
    </startup>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="BasicHttpBinding_IServiceSDB">
                    <security mode="Transport"/>
                </binding>
            </basicHttpBinding>
        </bindings>
        <client>
            <endpoint address="https://localhost/WcfServiceSDBSll/ServiceSDB.svc" binding="basicHttpBinding"
                bindingConfiguration="BasicHttpBinding_IServiceSDB" contract="WcfServiceSDB.IServiceSDB" name="BasicHttpBinding_IServiceSDB"/>
        </client>
    </system.serviceModel>
</configuration>